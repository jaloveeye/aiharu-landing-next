# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Local AI rollout (all features are disabled when LOCAL_AI_FEATURES is empty)
# LOCAL_AI_REQUIRE_LOCAL and LOCAL_SCHEDULE_PREFLIGHT_ERROR are scheduler-managed; do not set them here.
LOCAL_AI_FEATURES=
LOCAL_LLM_BASE_URL=http://127.0.0.1:8000/v1
LOCAL_LLM_API_KEY=local
LOCAL_LLM_MODEL=qwen3.6-35b-a3b
LOCAL_EMBEDDING_BASE_URL=http://127.0.0.1:8001/v1
LOCAL_EMBEDDING_API_KEY=local
LOCAL_EMBEDDING_MODEL=BAAI/bge-m3
# Keep legacy OpenAI embeddings during the comparison period
LOCAL_EMBEDDING_DUAL_WRITE=true

# Scheduled local worker (copy required server values to
# ~/.config/aiharu/scheduled.env and chmod 600 that file)
AIHARU_PROJECT_DIR=/home/herace/workspace/aiharu-landing-next
VLLM_IMAGE=nvcr.io/nvidia/vllm:26.05.post1-py3
HF_CACHE_DIR=/home/herace/.cache/huggingface
QWEN_HF_REVISION=95a723d08a9490559dae23d0cff1d9466213d989
BGE_HF_REVISION=5617a9f61b028005a4858fdac845db406aefb181
QWEN_HF_REVISION=95a723d08a9490559dae23d0cff1d9466213d989
BGE_HF_REVISION=5617a9f61b028005a4858fdac845db406aefb181
MODEL_START_TIMEOUT_SECONDS=1200
# Optional: send scheduled operation failures to an HTTPS JSON webhook
AIHARU_ALERT_WEBHOOK_URL=

# Internal operations API authentication (use a random value of at least 32 bytes)
# Example: openssl rand -hex 32
INTERNAL_API_SECRET=your_internal_api_secret_here

# Supabase Configuration (기존)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Encryption Key (API 히스토리 암호화용)
# ⚠️ 중요: API 발급 서버(connect-agent.aiharu.net)와 동일한 키를 사용해야 합니다!
# 32자 이상의 랜덤 문자열을 생성하여 사용하세요
# 예: openssl rand -hex 32
ENCRYPTION_KEY=your_encryption_key_here_minimum_32_characters

# News API Configuration
NEWS_API_KEY=your_news_api_key_here
GNEWS_API_KEY=your_gnews_api_key_here

# YouTube API Configuration
YOUTUBE_API_KEY=your_youtube_api_key_here

# Other Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Direct scheduler target (scheduler host only)
AIHARU_URL=https://aiharu.net
